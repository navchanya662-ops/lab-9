@productId =

###
# Сервер працює
GET {{baseUrl}}/

###
# Login власника товару
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "ivan@example.com",
  "password": "password123"
}

###
# Створити товар токеном власника
POST {{baseUrl}}/api/products
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "name": "Ноутбук Lenovo",
  "description": "Ноутбук для навчання та роботи",
  "price": 25000,
  "category": "Електроніка",
  "stock": 12
}

###
# Login іншого користувача
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "other@example.com",
  "password": "password123"
}

###
# ЛР12. Оновлення чужого товару, очікується 403
PUT {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{otherUserToken}}
Content-Type: application/json

{
  "price": 19999
}

###
# ЛР12. Оновлення свого товару, очікується 200
PUT {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "price": 23999,
  "stock": 10
}

###
# ЛР12. Прострочений токен, очікується 401
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{expiredToken}}

###
# ЛР12. Невірний токен, очікується 401
GET {{baseUrl}}/api/auth/me
Authorization: Bearer wrong.token.value
