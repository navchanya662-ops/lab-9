@baseUrl = http://localhost:3000
@token =
@adminToken =
@productId =

###
# Сервер працює
GET {{baseUrl}}/

###
# Вхід користувача
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "ivan@example.com",
  "password": "password123"
}

###
# Публічний список товарів без токена
GET {{baseUrl}}/api/products

###
# Створення товару без токена
POST {{baseUrl}}/api/products
Content-Type: application/json

{
  "name": "Ноутбук Lenovo",
  "description": "Ноутбук для навчання та роботи",
  "price": 25000,
  "category": "Електроніка",
  "stock": 12
}

###
# Створення товару з токеном user
POST {{baseUrl}}/api/products
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Ноутбук Lenovo",
  "description": "Ноутбук для навчання та роботи",
  "price": 25000,
  "category": "Електроніка",
  "stock": 12
}

###
# Отримати один товар
GET {{baseUrl}}/api/products/{{productId}}

###
# Оновити товар з токеном user
PUT {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "price": 23999,
  "stock": 10
}

###
# Видалити товар з токеном user, очікується 403
DELETE {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{token}}

###
# Видалити товар з токеном admin, очікується 200
DELETE {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{adminToken}}

###
# Некоректний id
GET {{baseUrl}}/api/products/wrong-id

###
# Неіснуючий маршрут
GET {{baseUrl}}/api/unknown-route
